<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Upload file</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <%- include('partials/nav', { navVariant: 'upload-file'}) %>

    <main class="container upload-page">
      <div class="login-container upload-container upload-split">
        <h2>Upload file</h2>
        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
          <div class="form-errors">
            <ul>
              <% errors.forEach(function (error) { %>
                <li><%= error.msg || error %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>
        <% if (typeof successMessage !== 'undefined' && successMessage) { %>
          <div class="form-success"><%= successMessage %></div>
        <% } %>

        <form
          action="/file?folder=<%=  parentId ? parentId : ''  %>"
          method="POST"
          enctype="multipart/form-data"
        >
          <div class="upload-panel" style="margin-bottom: 25px;">
            <h3 class="upload-panel-title">Destination</h3>
            <p class="upload-panel-hint">
              Parent folder:
              <strong><%= parentFolderName === null ? '/' : parentFolderName %></strong>
            </p>
          </div>

          <div class="form-group">
            <label for="name">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              maxlength="40"
              minlength="5"
              required
              value="<%= typeof oldInput !== 'undefined' && oldInput.name ? oldInput.name : '' %>"
            />
          </div>
          <div class="form-group">
            <label for="file">File</label>
            <input type="file" id="file" name="file" required />
          </div>
          <button type="submit" class="login-btn">Upload</button>
        </form>
      </div>
    </main>
  </body>
</html>
