<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Upload</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <%- include('partials/nav', { navVariant: 'upload' }) %>

    <main class="container upload-page">
      <div class="login-container upload-container">
        <h2>Upload a file</h2>
        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
          <div class="form-errors">
            <ul>
              <% errors.forEach(function (error) { %>
                <li><%= error.msg || error %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>
        <% if (typeof successMessage !== 'undefined' && successMessage) { %>
          <div class="form-success"><%= successMessage %></div>
        <% } %>
        <form action="/upload" method="POST" enctype="multipart/form-data">
          <div class="form-group">
            <label for="file">Choose file</label>
            <input
              type="file"
              id="file"
              name="file"
              required
            />
          </div>
          <button type="submit" class="login-btn">Upload</button>
        </form>
        <div class="signup-link">
          <a href="/">Back to home</a>
        </div>
      </div>
    </main>
  </body>
</html>
